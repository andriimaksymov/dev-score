# Backend Configuration
PORT=3001
NODE_ENV=development

# GitHub API
GITHUB_API_TOKEN=github_token_placeholder
GITHUB_API_BASE_URL=https://api.github.com

# CORS (Frontend URL)
FRONTEND_URL=http://localhost:5173

# OpenRouter (primary AI provider for analysis/validation)
# OPEN_ROUTER is also accepted as an alias for OPENROUTER_API_KEY.
OPENROUTER_API_KEY=openrouter_key_placeholder
# Fast, cheap, and reliably honors strict json_schema output.
# Free alternatives exist (e.g. nvidia/nemotron-3-super-120b-a12b:free,
# google/gemma-4-26b-a4b-it:free) but are noticeably slower / rate-limited.
OPENROUTER_MODEL=openai/gpt-4o-mini
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Gemini AI
GEMINI_API_KEY=gemini_key_placeholder

# Future: OpenAI Integration
OPENAI_API_KEY=openai_key_placeholder

# AI Provider Orchestration (first available provider wins)
AI_PROVIDER_ORDER=openrouter,openai,gemini,groq
OPENAI_MODEL=gpt-5-mini
GEMINI_MODEL=gemini-2.5-flash
GROQ_MODEL=openai/gpt-oss-120b

# Future: Database
DATABASE_URL=postgresql://user:password@localhost:5432/portfolio_analyzer
